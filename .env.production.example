# CodeLens Production Environment Variables Template
# Copy these keys into your Render Dashboard environment configuration

# Tells Express and React to run in optimized mode
NODE_ENV=production

# The port Render will assign (Render defaults to 10000 but sets PORT automatically)
PORT=5000

# Your MongoDB Atlas Connection String
# Example: mongodb+srv://<username>:<password>@cluster0.mongodb.net/codelens?retryWrites=true&w=majority
MONGODB_URI=your_mongodb_atlas_uri

# A long, random string used to sign user sessions
JWT_SECRET=generate_a_very_long_random_string_here

# Your NVIDIA API Key for the Qwen AI model
NVIDIA_API_KEY=your_nvidia_api_key_here

# The final public URL of your deployed app (e.g. https://codelens.onrender.com)
CLIENT_URL=https://your-app-name.onrender.com
